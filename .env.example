# Vercel Postgres — set automatically when you link a Vercel Postgres database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Admin dashboard password (you choose this)
ADMIN_PASSWORD=your-strong-password-here

# Secret used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here
